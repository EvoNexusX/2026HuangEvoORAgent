    "01": [(71.5,None),(71.8,"Cross"),(73.5,"Cross"),(77.8,"Cross"),(79.2,"Cross"),
           (80.1,"Cross"),(81.3,"Cross"),(81.9,"Cross"),(82.6,"Cross")],

