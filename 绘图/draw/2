# ======================
# Piecewise scaling
# ======================
def transform_y(y):
    if y < 60:
        return y * 0.5
    else:
        return 30 + (y - 60)*2

# ======================
# Colors
# ======================
colors = {
    "Elite": "#4C72B0",
    "Cross": "#DD8452",
    "Mut-L": "#55A868",
    "Mut-S": "#C44E52"
}

# ======================
# Plot
# ======================
plt.figure(figsize=(8,12))

for ind, traj in data.items():
    for g in range(len(traj)):
        score, op = traj[g]
        y = transform_y(score)

        # ---------- G0 ----------
        if g == 0:
            plt.scatter(g, y, s=85, color="black", zorder=5)

        else:
            prev_score = traj[g-1][0]
            prev_y = transform_y(prev_score)

            if op == "Elite":
                # 点
                plt.scatter(g, y, s=90,
                            color=colors["Elite"],
                            edgecolor="black",
                            linewidth=0.4,
                            zorder=5)

                # ← 水平箭头（不变）
                plt.annotate("",
                             xy=(g-1, prev_y),
                             xytext=(g, prev_y),
                             arrowprops=dict(
                                 arrowstyle="->",
                                 color=colors["Elite"],
                                 lw=1.8,
                                 alpha=0.9
                             ),
                             zorder=3)

            else:
                plt.scatter(g, y, s=75,
                            color=colors.get(op, "#999999"),
                            alpha=0.9,
                            zorder=4)

        # ======================
        # Label（仅这里做避让）
        # ======================
        y_text = y

        if g > 0 and op == "Elite":
            prev_score = traj[g-1][0]
            prev_y = transform_y(prev_score)

            # 如果接近箭头线 → 上移文字
            if abs(y - prev_y) < 1.0:
                y_text = y + 1.2

        plt.text(g + 0.1, y_text,
                 f"{score:.1f}",
                 ha='left', va='center',
                 fontsize=9)

# ======================
# Axis
# ======================
plt.xlabel("Generation", fontsize=13)
plt.ylabel("Train WA (%)", fontsize=13)

plt.xticks(range(9))

yticks_real = [40, 50, 60, 70, 80]
yticks_trans = [transform_y(y) for y in yticks_real]
plt.yticks(yticks_trans, yticks_real)

plt.grid(alpha=0.2)

